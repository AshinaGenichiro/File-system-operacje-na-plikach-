<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp9.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Entry
                 x:Name="textEntry"
                 Placeholder="Wpisz swoj tekst do notatki"
                 FontSize="18" />
            <Button
                Text="Zapisz do pliu"
                Clicked="OnSaveButtonClicked"
                />
            <Button
                Text="Odczytaj z pliku"
                Clicked="OnReadButtonClicked"
                />
            <Label
                x:Name="resultLabel"
                FontSize="18" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
